@model IEnumerable<Library.MVC.Models.Book>
@{
    ViewData["Title"] = "Books";
}

<h2>Books</h2>
<a asp-action="Create" class="btn btn-success mb-3">+ Add Book</a>

<form method="get" asp-action="Index" class="row g-2 mb-4">
    <div class="col-md-4">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by title or author..." />
    </div>
    <div class="col-md-3">
        <select name="category" class="form-select">
            <option value="">All Categories</option>
            @foreach (var cat in ViewBag.Categories as List<string> ?? new List<string>())
            {
                <option value="@cat" selected="@(ViewBag.Category == cat ? "selected" : null)">@cat</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <select name="availability" class="form-select">
            <option value="">All</option>
            <option value="Available" selected="@(ViewBag.Availability == "Available" ? "selected" : null)">Available</option>
            <option value="OnLoan" selected="@(ViewBag.Availability == "OnLoan" ? "selected" : null)">On Loan</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Filter</button>
    </div>
</form>

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>Title</th>
            <th>Author</th>
            <th>ISBN</th>
            <th>Category</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model)
        {
            <tr>
                <td>@book.Title</td>
                <td>@book.Author</td>
                <td>@book.Isbn</td>
                <td>@book.Category</td>
                <td>
                    @if (book.IsAvailable)
                    {
                        <span class="badge bg-success">Available</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">On Loan</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@book.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>