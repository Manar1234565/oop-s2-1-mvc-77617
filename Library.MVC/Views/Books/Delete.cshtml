@model Library.MVC.Models.Book
@{
    ViewData["Title"] = "Delete Book";
}
<h2>Delete Book</h2>
<div class="alert alert-danger">
    Are you sure you want to delete this book?
</div>
<dl class="row">
    <dt class="col-sm-2">Title</dt>
    <dd class="col-sm-10">@Model.Title</dd>
    <dt class="col-sm-2">Author</dt>
    <dd class="col-sm-10">@Model.Author</dd>
    <dt class="col-sm-2">ISBN</dt>
    <dd class="col-sm-10">@Model.Isbn</dd>
    <dt class="col-sm-2">Category</dt>
    <dd class="col-sm-10">@Model.Category</dd>
</dl>
<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>