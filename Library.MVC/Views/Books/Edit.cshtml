@model Library.MVC.Models.Book
@{
    ViewData["Title"] = "Edit Book";
}
<h2>Edit Book</h2>
<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="mb-3">
        <label class="form-label">Title</label>
        <input asp-for="Title" class="form-control" required />
    </div>
    <div class="mb-3">
        <label class="form-label">Author</label>
        <input asp-for="Author" class="form-control" required />
    </div>
    <div class="mb-3">
        <label class="form-label">ISBN</label>
        <input asp-for="Isbn" class="form-control" required />
    </div>
    <div class="mb-3">
        <label class="form-label">Category</label>
        <input asp-for="Category" class="form-control" required />
    </div>
    <div class="mb-3">
        <label class="form-label">Available</label>
        <input asp-for="IsAvailable" class="form-check-input" type="checkbox" />
    </div>
    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>